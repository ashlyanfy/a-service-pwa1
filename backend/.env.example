# Разрешённые origins (JSON-массив строк)
ALLOWED_ORIGINS=["http://localhost:3000","https://your-site.netlify.app"]

# Лимит запросов: 5 заявок с одного IP в 60 секунд
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60

# Redis (запущен локально или через Docker)
REDIS_URL=redis://localhost:6379/0

# Gmail SMTP (нужен App Password, не обычный пароль)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
RECIPIENT_EMAIL=ashlyanfy@gmail.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopqrstuvwxyz
TELEGRAM_CHAT_ID=123456789